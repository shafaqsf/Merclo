# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenRouter (OpenAI-compatible endpoint used by the agent runtime)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Default model slug routed through OpenRouter (e.g. openai/gpt-4o-mini)
AGENT_MODEL=openai/gpt-4o-mini

# Public base URL of this app (used by the widget snippet to call back)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Dashboard auth switch (DEV ONLY). Set to "true" to bypass the login gate and
# open the dashboard without a Supabase session. Leave unset/empty in any
# deployed environment. DASHBOARD_DEV_EMAIL sets the placeholder email shown.
DASHBOARD_AUTH_DISABLED=
DASHBOARD_DEV_EMAIL=
