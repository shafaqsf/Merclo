# Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# OpenRouter (OpenAI-compatible endpoint used by the agent runtime)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Default model slug routed through OpenRouter (e.g. openai/gpt-4o-mini)
AGENT_MODEL=openai/gpt-4o-mini

# Public base URL of this app (used by the widget snippet to call back)
NEXT_PUBLIC_APP_URL=http://localhost:3000
